{{#if background}}
<picture>
    <source
        data-srcset="{{img_url background size="s" format="avif"}} 300w,
                {{img_url background size="m" format="avif"}} 600w,
                {{img_url background size="l" format="avif"}} 1000w,
                {{img_url background size="xl" format="avif"}} 2000w"
        type="image/avif"
    >
    <img class="image-inset blur-up lazyload"
        src="data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw=="
        data-srcset="{{img_url background size="s" format="webp"}} 300w,
                {{img_url background size="m" format="webp"}} 600w,
                {{img_url background size="l" format="webp"}} 1000w,
                {{img_url background size="xl" format="webp"}} 2000w"
        data-sizes="auto"
        width="1200"
        height="628"
        alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{alt_title}}{{/if}}"
    />
</picture>

{{#if has_gradient}}<div class="M4-cover-gradient absolute inset-0 z-2 bg-black bg-opacity-50"></div>{{/if}}
{{/if}}
