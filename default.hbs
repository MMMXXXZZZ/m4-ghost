<html lang="{{@site.locale}}"{{#match @custom.color_scheme "Dark"}} class="dark"{{/match}}>
<head>
    {{!-- View Transitions — same-origin navigation fades (Chrome/Safari) --}}
    <meta name="view-transition" content="same-origin">
    <style>
      @view-transition { navigation: auto; }
    </style>

    {{!-- Document Settings --}}
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    {{!-- Base Meta --}}
    <title>{{meta_title}}</title>
    <meta name="HandheldFriendly" content="True" />
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <script>
    {{#match @custom.color_scheme "Auto"}}
        if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.querySelector('html').classList.add('dark');
        } else {
            document.querySelector('html').classList.remove('dark');
        }
    {{else}}
        if (localStorage.theme === 'dark') {
            document.querySelector('html').classList.add('dark');
        } else if (localStorage.theme === 'light') {
            document.querySelector('html').classList.remove('dark');
        }
    {{/match}}
    </script>

    {{!-- ═══════════════════════════════════════════════════════════════
         LOADING SCREEN — return-visit gate only.
         The Worker (m4-splash) owns the full splash on cache misses.
         This one-liner adds .m4-skip to <html> before first paint so
         the Worker's #m4-loader is hidden instantly on return visits
         where sessionStorage already has 'm4_vis' set.
    ═══════════════════════════════════════════════════════════════ --}}
    <script>if(sessionStorage.getItem('m4_vis'))document.documentElement.classList.add('m4-skip');</script>
    <style>.m4-skip #m4-loader{display:none!important}</style>

    {{!-- ═══════════════════════════════════════════════════════════════
         FADE-IN — masks FOUT (flash of fallback font before Space
         Grotesk applies) on every page load.

         Two-layer approach:
           1. body fades in over 250ms — font swaps invisibly inside
           2. .site-wrapper direct children stagger top→bottom
              with a subtle upward drift for depth

         Suppressed on View Transitions navigations via body.m4-loaded:
           After the first fade completes, JS adds .m4-loaded to body.
           View Transitions navigate to a new document, DOMContentLoaded
           fires again, but the .m4-loaded class is NOT present on the
           new document — so the fade fires once per page load, which is
           exactly what we want. View Transitions then crossfade the two
           states, so both effects layer naturally without conflict.

         Suppressed for users who prefer reduced motion.
    ═══════════════════════════════════════════════════════════════ --}}
    <style>
        @media (prefers-reduced-motion: no-preference) {

            /* ── Keyframes ── */
            @keyframes m4-fadein {
                from { opacity: 0; transform: translateY(6px); }
                to   { opacity: 1; transform: translateY(0);   }
            }

            /* ── Body — short fade masks font swap ── */
            body {
                animation: m4-fadein 0.25s ease-out both;
            }

            /* ── Site sections — staggered cascade ── */
            .site-wrapper > * {
                animation: m4-fadein 0.4s ease-out both;
            }
            .site-wrapper > *:nth-child(1) { animation-delay: 0.04s; }
            .site-wrapper > *:nth-child(2) { animation-delay: 0.10s; }
            .site-wrapper > *:nth-child(3) { animation-delay: 0.16s; }
            .site-wrapper > *:nth-child(4) { animation-delay: 0.22s; }
            .site-wrapper > *:nth-child(5) { animation-delay: 0.28s; }

            /* ── Post/article body content — fine-grained cascade ──
               Targets direct children of the article body so headings,
               paragraphs, figures, code blocks each drift in separately.
               10 elements covers most articles; beyond that they share
               the last delay (no jump, just grouped).
            ── */
            .post-body > * {
                animation: m4-fadein 0.45s ease-out both;
            }
            .post-body > *:nth-child(1)  { animation-delay: 0.05s; }
            .post-body > *:nth-child(2)  { animation-delay: 0.09s; }
            .post-body > *:nth-child(3)  { animation-delay: 0.13s; }
            .post-body > *:nth-child(4)  { animation-delay: 0.17s; }
            .post-body > *:nth-child(5)  { animation-delay: 0.21s; }
            .post-body > *:nth-child(6)  { animation-delay: 0.25s; }
            .post-body > *:nth-child(7)  { animation-delay: 0.29s; }
            .post-body > *:nth-child(8)  { animation-delay: 0.33s; }
            .post-body > *:nth-child(9)  { animation-delay: 0.37s; }
            .post-body > *:nth-child(10) { animation-delay: 0.41s; }

        }
    </style>

    {{!-- Fonts -> Space Grotesk=variable; JetBrains Mono=variable (for code) --}}
    <link rel="preload" href="{{asset 'fonts/SpaceGrotesk-VariableFont_wght.ttf'}}" as="font" type="font/ttf" crossorigin>

    {{!-- Theme styles --}}
    <link rel="stylesheet" type="text/css" href="{{asset "styles/main.css"}}"/>

    {{!-- MeiliSearch Search UI styles (custom theme override) --}}
    <link rel="stylesheet" type="text/css" href="https://m44.cl/content/files/ghost-meilisearch-search-ui-m4.css">

    <style>
        :root {
            {{#if @custom.header_has_color}}
            --header-logo-color: #fff;
            --header-bg: {{@custom.header_background}};
            --header-color: {{@custom.header_text_color}};
            --header-color-hover: {{@custom.header_text_color_hover}};
            {{/if}}
            --logo-width: {{#if @custom.logo_width}}{{@custom.logo_width}}{{else}}11.25rem{{/if}};
        }
    </style>

    {{!-- Ghost outputs important style and meta data with this tag --}}
    {{ghost_head}}

    {{!-- MeiliSearch Search UI bundle — loaded with defer so it doesn't block
         rendering. meilisearch.js in the theme bundle polls for it after
         DOMContentLoaded in case it hasn't executed yet.                    --}}
    <script defer src="https://cdn.jsdelivr.net/npm/@fanyangmeng/ghost-meilisearch-search-ui@1.2.3/dist/search.min.js"></script>
</head>
<body class="{{{block "M4_class_body"}}}">

    <div class="site-wrapper flex flex-col justify-start min-h-screen">
        {{!-- Header --}}
        {{> "layout/header"}}

        {{!-- Promo Popup --}}
        <div id="js-promo-popup" class="promo-popup"></div>

        {{!-- Main content --}}
        <main class="site-main">{{{body}}}</main>

        {{!-- Footer --}}
        {{> "layout/footer"}}

        {{!-- Mobile Menu --}}
        {{> "layout/mobile-menu"}}
    </div>

    {{!-- Site URL --}}
    <script>
        var siteUrl = '{{@site.url}}';
        var prismJs = '{{asset "scripts/prismjs.js"}}';
        var prismJsComponents = 'https://cdnjs.cloudflare.com/ajax/libs/prism/1.25.0/components/';
        var M4Gallery = {{@custom.gallery}};
    </script>

    {{!-- Icons --}}
    {{> "icons/icons-symbol-defs"}}

    {{!-- Ghost outputs important scripts with this tag --}}
    {{ghost_foot}}

    {{!-- Theme JavaScript --}}
    <script src="{{#is "post, page"}}{{asset "scripts/post.js"}}{{else}}{{asset "scripts/main.js"}}{{/is}}"></script>

    {{#if pagination.pages}}<script src="{{asset "scripts/pagination.js"}}" async defer></script>{{/if}}

    {{{block "scripts"}}}
</body>
</html>
